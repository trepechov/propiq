# PropIQ environment variables
#
# Server-only (no NEXT_PUBLIC_ prefix — these MUST NOT be sent to the browser).
# Next.js only exposes NEXT_PUBLIC_ vars to the client bundle.
# GEMINI_API_KEY is intentionally server-only to prevent API key exposure.
GEMINI_API_KEY=

# Browser-accessible (Supabase anon key is designed for public browser use).
# RLS policies on the Supabase side enforce data access control.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
